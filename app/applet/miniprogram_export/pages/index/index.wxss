.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
  background: radial-gradient(circle at center, #1e293b 0%, #0f172a 100%);
}
.hero {
  text-align: center;
  margin-bottom: 120rpx;
}
.title {
  font-size: 80rpx;
  font-weight: bold;
  letter-spacing: 8rpx;
  margin-bottom: 30rpx;
  color: #f8fafc;
  text-shadow: 0 0 20rpx rgba(255,255,255,0.2);
}
.subtitle {
  font-size: 32rpx;
  color: #94a3b8;
  letter-spacing: 4rpx;
}
.start-btn {
  background-color: transparent !important;
  border: 2rpx solid #f8fafc !important;
  color: #f8fafc !important;
  border-radius: 100rpx;
  padding: 20rpx 80rpx;
  font-size: 36rpx;
  letter-spacing: 4rpx;
  font-weight: normal;
}
.start-btn::after {
  border: none;
}
