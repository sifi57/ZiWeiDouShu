.container {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}
.progress-bar {
  width: 100%;
  height: 8rpx;
  background-color: #334155;
  border-radius: 4rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}
.progress-inner {
  height: 100%;
  background-color: #e2e8f0;
  transition: width 0.3s ease;
}
.question-count {
  font-size: 28rpx;
  color: #94a3b8;
  text-align: center;
  margin-bottom: 60rpx;
  letter-spacing: 4rpx;
}
.question-text {
  font-size: 40rpx;
  line-height: 1.6;
  margin-bottom: 80rpx;
  text-align: justify;
  color: #f8fafc;
}
.options-container {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}
.option-btn {
  background-color: rgba(30, 41, 59, 0.5);
  border: 2rpx solid #334155;
  border-radius: 16rpx;
  padding: 30rpx 40rpx;
  font-size: 32rpx;
  color: #cbd5e1;
  transition: all 0.2s;
}
.option-btn:active {
  background-color: #334155;
  border-color: #475569;
}
